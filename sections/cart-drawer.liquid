{%- liquid
  assign opacity_decimal = section.settings.background_opacity | times: 1.0 | divided_by: 100.0
  assign tint_color = section.settings.background_color | color_modify: 'alpha', opacity_decimal
-%}

<div
  id="CartDrawer"
  class="cart-drawer"
  data-cart-drawer
  aria-hidden="true"
  data-cart-add-url="{{ routes.cart_add_url }}"
  data-cart-change-url="{{ routes.cart_change_url }}"
  style="
    --cart-drawer-tint: {{ tint_color }};
    --cart-drawer-image: {% if section.settings.background_type == 'image' and section.settings.background_image != blank %}url('{{ section.settings.background_image | image_url: width: 2000 }}'){% else %}none{% endif %};
  "
>
  <span class="visually-hidden" data-cart-drawer-count>{{ cart.item_count }}</span>

  <div class="cart-drawer__panel" data-cart-drawer-panel role="dialog" aria-modal="true" aria-labelledby="CartDrawerHeading">
    <div class="cart-drawer__surface">
      <button type="button" class="cart-drawer__close" data-cart-drawer-close aria-label="{{ 'cart.drawer.close' | t }}">
        &times;
      </button>

      <div class="cart-drawer__inner">
        <h2 id="CartDrawerHeading" class="cart-drawer__heading">{{ section.settings.heading }}</h2>

        <div class="cart-drawer__body" data-cart-drawer-body>
          {%- if cart.item_count == 0 -%}
            <p class="cart-drawer__empty" data-cart-drawer-empty>{{ section.settings.empty_text }}</p>
          {%- else -%}
            <ul class="cart-drawer__items" role="list" data-cart-drawer-items>
              {%- for item in cart.items -%}
                {%- render 'cart-drawer-item', item: item, item_index: forloop.index -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        <div class="cart-drawer__footer" data-cart-drawer-footer>
          {%- if cart.item_count > 0 -%}
            <div class="cart-drawer__subtotal">
              <span>{{ 'cart.drawer.subtotal' | t }}</span>
              <span data-cart-drawer-subtotal>{{ cart.total_price | money }}</span>
            </div>
            <a href="/checkout" class="cart-drawer__checkout" data-cart-drawer-checkout-btn>
              {{ section.settings.checkout_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <button type="button" class="cart-drawer__handle" data-cart-drawer-handle aria-label="{{ 'cart.drawer.drag_to_close' | t }}"></button>
    </div>
  </div>
</div>

<script src="{{ 'cart-drawer.js' | asset_url }}" defer></script>

{% stylesheet %}
  html.cart-drawer-locked,
  html.cart-drawer-locked body {
    overflow: hidden;
  }

  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 500;
    transform: translateX(-100%);
    transition: transform 0.55s cubic-bezier(0.45, 0.05, 0.15, 1);
    pointer-events: none;
  }

  .cart-drawer.is-open {
    transform: translateX(0);
    pointer-events: auto;
  }

  .cart-drawer.is-loading .cart-drawer__body {
    opacity: 0.5;
    pointer-events: none;
  }

  .cart-drawer__panel {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .cart-drawer__panel.is-dragging {
    transition: none;
  }

  .cart-drawer__surface {
    position: relative;
    width: 100%;
    height: 100%;
    color: #fff;
    background-color: #0b0b0d;
    background-image: linear-gradient(var(--cart-drawer-tint), var(--cart-drawer-tint)), var(--cart-drawer-image);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .cart-drawer__close {
    appearance: none;
    position: absolute;
    top: 2.4rem;
    right: 2.4rem;
    z-index: 2;
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.35);
    color: #fff;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .cart-drawer__close:hover,
  .cart-drawer__close:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .cart-drawer__handle {
    appearance: none;
    position: absolute;
    top: 0;
    right: 0;
    width: 2.4rem;
    height: 100%;
    border: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08));
    cursor: grab;
    touch-action: none;
  }

  .cart-drawer__handle::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 0.8rem;
    width: 0.4rem;
    height: 6rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.35);
  }

  .cart-drawer__handle:active {
    cursor: grabbing;
  }

  .cart-drawer__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    max-width: 64rem;
    margin: 0 auto;
    padding: 8rem 2.4rem 4rem;
  }

  .cart-drawer__heading {
    margin: 0 0 2.4rem;
    font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    transition: opacity 0.2s ease;
  }

  .cart-drawer__empty {
    opacity: 0.75;
    font-size: 1.5rem;
  }

  .cart-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .cart-drawer__footer {
    position: sticky;
    bottom: 0;
    padding-top: 2rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 40%, transparent);
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.6rem;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .cart-drawer__checkout {
    display: block;
    width: 100%;
    text-align: center;
    appearance: none;
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: #fff;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1.5rem 2rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .cart-drawer__checkout:hover,
  .cart-drawer__checkout:focus-visible {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .cart-drawer__inner {
      padding: 7rem 1.6rem 3rem;
    }

    .cart-drawer__handle {
      width: 1.8rem;
    }
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: 9.6rem 1fr;
    gap: 1.6rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .cart-drawer__item-model {
    position: relative;
    width: 9.6rem;
    height: 9.6rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cart-drawer__item-model-viewer {
    display: block;
    width: 100%;
    height: 100%;
    /* Ambient decoration, not an interactive viewer — it shouldn't compete
       with scrolling the item list or dragging the drawer's close handle. */
    pointer-events: none;
    --poster-color: transparent;
  }

  .cart-drawer__item-image-fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-drawer__item-details {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-width: 0;
  }

  .cart-drawer__item-title {
    color: inherit;
    font-size: 1.5rem;
    letter-spacing: 0.01em;
  }

  .cart-drawer__item-title:hover,
  .cart-drawer__item-title:focus-visible {
    color: var(--color-accent);
  }

  .cart-drawer__item-variant {
    margin: 0;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  .cart-drawer__item-options {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
  }

  .cart-drawer__option {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .cart-drawer__option-select {
    appearance: none;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font: inherit;
    font-size: 1.2rem;
    padding: 0.5rem 0.8rem;
  }

  .cart-drawer__option-error {
    flex-basis: 100%;
    margin: 0;
    color: #ffb3b3;
    font-size: 1.1rem;
  }

  .cart-drawer__item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    margin-top: 0.4rem;
  }

  .cart-drawer__quantity {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .cart-drawer__qty-btn {
    appearance: none;
    width: 3.2rem;
    height: 3.2rem;
    border: 0;
    background: transparent;
    color: #fff;
    font-size: 1.6rem;
    cursor: pointer;
  }

  .cart-drawer__qty-btn:hover,
  .cart-drawer__qty-btn:focus-visible {
    color: var(--color-accent);
  }

  .cart-drawer__qty-input {
    appearance: none;
    -moz-appearance: textfield;
    width: 4rem;
    height: 3.2rem;
    border: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.25);
    border-right: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    color: #fff;
    text-align: center;
    font: inherit;
    font-size: 1.3rem;
  }

  .cart-drawer__qty-input::-webkit-outer-spin-button,
  .cart-drawer__qty-input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .cart-drawer__item-price {
    font-size: 1.3rem;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .cart-drawer__remove {
    appearance: none;
    align-self: flex-start;
    border: 0;
    background: transparent;
    color: rgba(255, 255, 255, 0.55);
    font: inherit;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }

  .cart-drawer__remove:hover,
  .cart-drawer__remove:focus-visible {
    color: #fff;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "tag": "div",
  "class": "section-cart-drawer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cart_drawer.settings.heading.label",
      "default": "Your cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "t:sections.cart_drawer.settings.empty_text.label",
      "default": "Your cart is empty."
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "t:sections.cart_drawer.settings.checkout_label.label",
      "default": "Checkout"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "t:sections.cart_drawer.settings.background_type.label",
      "options": [
        {
          "value": "color",
          "label": "t:sections.cart_drawer.settings.background_type.options.color"
        },
        {
          "value": "image",
          "label": "t:sections.cart_drawer.settings.background_type.options.image"
        }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.cart_drawer.settings.background_color.label",
      "default": "#0b0b0d"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "label": "t:sections.cart_drawer.settings.background_opacity.label",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.cart_drawer.settings.background_image.label"
    }
  ]
}
{% endschema %}
