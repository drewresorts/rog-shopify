{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section
  class="product-page"
  data-product-page
  data-cart-add-url="{{ routes.cart_add_url }}"
  aria-labelledby="ProductPageHeading"
>
  <div class="product-page__inner">
    <div class="product-page__media">
      {%- if product.featured_media -%}
        {{
          product.featured_media
          | image_url: width: 1200
          | image_tag:
            class: 'product-page__image',
            loading: 'eager',
            widths: '400, 600, 800, 1000, 1200',
            sizes: '(min-width: 990px) 48rem, 90vw',
            alt: product.featured_media.alt | default: product.title
        }}
      {%- endif -%}
    </div>

    <div class="product-page__details">
      <h1 id="ProductPageHeading" class="product-page__title">{{ product.title }}</h1>
      <p class="product-page__price" data-product-price>{{ current_variant.price | money }}</p>

      {%- form 'product', product, id: 'ProductForm', class: 'product-page__form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-product-variant-id>

        {%- if product.has_only_default_variant == false -%}
          <div
            class="product-page__options"
            data-product-options
            data-variants="{{ product.variants | json | escape }}"
          >
            {%- for option in product.options_with_values -%}
              {%- assign selected_value = current_variant.options[forloop.index0] -%}
              <label class="product-page__option">
                <span class="product-page__option-label">{{ option.name }}</span>
                <select class="product-page__option-select" data-option-index="{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}" {% if value == selected_value %}selected{% endif %}>
                      {{ value }}
                    </option>
                  {%- endfor -%}
                </select>
              </label>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <label class="product-page__quantity-label">
          Quantity
          <input type="number" name="quantity" min="1" value="1" class="product-page__quantity-input">
        </label>

        <button
          type="submit"
          class="product-page__submit"
          data-product-submit
          {% unless current_variant.available %}disabled{% endunless %}
        >
          <span data-product-submit-text>
            {%- if current_variant.available -%}
              Add to cart
            {%- else -%}
              Sold out
            {%- endif -%}
          </span>
        </button>

        <p class="product-page__error" data-product-error hidden></p>
      {%- endform -%}

      {%- if product.description != blank -%}
        <div class="product-page__description">{{ product.description }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>window.ROGMoneyFormat = {{ shop.money_format | json }};</script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

{% stylesheet %}
  .product-page {
    min-height: 100vh;
    padding: 16rem 2.4rem 8rem;
    background: #0b0b0d;
    color: #fff;
  }

  .product-page__inner {
    max-width: 108rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  .product-page__image {
    width: 100%;
    box-shadow: 0 2.4rem 6rem rgba(0, 0, 0, 0.45);
  }

  .product-page__title {
    margin: 0 0 1.2rem;
    font-size: clamp(2.8rem, 5vw, 4.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .product-page__price {
    margin: 0 0 2.8rem;
    font-size: 1.8rem;
    letter-spacing: 0.04em;
    color: var(--color-accent);
  }

  .product-page__form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 36rem;
  }

  .product-page__options {
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
  }

  .product-page__option {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .product-page__option-select {
    appearance: none;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font: inherit;
    font-size: 1.3rem;
    padding: 0.8rem 1.2rem;
  }

  .product-page__quantity-label {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 10rem;
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .product-page__quantity-input {
    appearance: none;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    font: inherit;
    font-size: 1.3rem;
    padding: 0.8rem 1.2rem;
  }

  .product-page__submit {
    appearance: none;
    border: 1px solid var(--color-accent);
    background: var(--color-accent);
    color: #fff;
    font: inherit;
    font-size: 1.3rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 1.4rem 2rem;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .product-page__submit:hover,
  .product-page__submit:focus-visible {
    opacity: 0.85;
  }

  .product-page__submit:disabled {
    opacity: 0.4;
    cursor: default;
  }

  .product-page__error {
    margin: 0;
    color: #ffb3b3;
    font-size: 1.2rem;
  }

  .product-page__description {
    margin-top: 3.2rem;
    max-width: 60rem;
    font-size: 1.4rem;
    line-height: 1.7;
    opacity: 0.8;
  }

  @media screen and (min-width: 990px) {
    .product-page__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 44rem);
      align-items: start;
    }
  }

  @media screen and (max-width: 749px) {
    .product-page {
      padding-top: 14rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_page.name",
  "tag": "section",
  "class": "section-product-page",
  "settings": []
}
{% endschema %}
