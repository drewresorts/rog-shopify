{%- if section.settings.collection != blank -%}
  {%- assign collection = section.settings.collection -%}

  <section class="featured-collection" aria-labelledby="FeaturedCollection-{{ section.id }}">
    <div class="featured-collection__inner">
      {%- if section.settings.heading != blank -%}
        <h2 id="FeaturedCollection-{{ section.id }}" class="featured-collection__heading visually-hidden">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <ul class="featured-collection__pond" role="list">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <li class="featured-collection__buoy" data-floating-item>
            <a class="featured-collection__buoy-link" href="{{ product.url }}">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag:
                    class: 'featured-collection__image',
                    loading: 'lazy',
                    widths: '200, 300, 450, 600',
                    sizes: '(min-width: 990px) 18rem, 42vw',
                    alt: product.featured_image.alt | default: product.title
                }}
              {%- endif -%}
              <span class="featured-collection__title">{{ product.title }}</span>
              <span class="featured-collection__price">{{ product.price | money }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- endif -%}

<script src="{{ 'featured-floating.js' | asset_url }}" defer></script>

{% stylesheet %}
  .featured-collection {
    position: relative;
    z-index: 2;
    padding: 2.4rem 2.4rem 6rem;
    background: transparent;
    color: #fff;
  }

  .featured-collection__inner {
    max-width: 120rem;
    margin: 0 auto;
  }

  .featured-collection__pond {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3.2rem 2.4rem;
  }

  .featured-collection__buoy {
    width: 16rem;
    will-change: transform;
  }

  .featured-collection__buoy-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: inherit;
    text-align: center;
    text-shadow: 0 1.2rem 4rem rgba(0, 0, 0, 0.65);
  }

  .featured-collection__image {
    width: 100%;
    box-shadow: 0 1.6rem 4rem rgba(0, 0, 0, 0.45);
    transition: transform 0.2s ease;
  }

  .featured-collection__buoy-link:hover .featured-collection__image,
  .featured-collection__buoy-link:focus-visible .featured-collection__image {
    transform: scale(1.03);
  }

  .featured-collection__title {
    font-size: 1.2rem;
    letter-spacing: 0.03em;
  }

  .featured-collection__price {
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media screen and (max-width: 749px) {
    .featured-collection {
      padding-top: 1.2rem;
    }

    .featured-collection__buoy {
      width: 13rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading.label",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show.label",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name"
    }
  ]
}
{% endschema %}
