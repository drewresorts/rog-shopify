{%- if section.settings.collection != blank -%}
  {%- assign collection = section.settings.collection -%}

  <section class="featured-collection" aria-labelledby="FeaturedCollection-{{ section.id }}">
    <div class="featured-collection__inner">
      {%- if section.settings.heading != blank -%}
        <h2 id="FeaturedCollection-{{ section.id }}" class="featured-collection__heading visually-hidden">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <ul class="featured-collection__grid" role="list">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <li class="featured-collection__item">
            <a class="featured-collection__link" href="{{ product.url }}">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'featured-collection__image',
                    loading: 'lazy',
                    widths: '300, 450, 600, 900',
                    sizes: '(min-width: 990px) 28rem, 80vw',
                    alt: product.featured_image.alt | default: product.title
                }}
              {%- endif -%}
              <span class="featured-collection__title">{{ product.title }}</span>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .featured-collection {
    position: relative;
    z-index: 2;
    padding: 8rem 2.4rem 12rem;
    background: transparent;
    color: #fff;
  }

  .featured-collection__inner {
    max-width: 120rem;
    margin: 0 auto;
  }

  .featured-collection__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8rem 2.4rem;
    justify-items: center;
  }

  .featured-collection__item {
    width: min(32rem, 100%);
  }

  .featured-collection__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.6rem;
    color: inherit;
    text-shadow: 0 1.2rem 4rem rgba(0, 0, 0, 0.65);
  }

  .featured-collection__image {
    width: 100%;
    box-shadow: 0 2.4rem 6rem rgba(0, 0, 0, 0.45);
  }

  .featured-collection__title {
    font-size: 1.3rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-accent);
  }

  @media screen and (min-width: 750px) {
    .featured-collection__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .featured-collection__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "class": "section-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading.label",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:sections.featured_collection.settings.products_to_show.label",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name"
    }
  ]
}
{% endschema %}
